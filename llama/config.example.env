# Copy this file to llama/config.env and edit the paths for your machine.

# Path to your llama.cpp server binary.
LLAMA_BIN=/absolute/path/to/llama.cpp/build/bin/llama-server

# Path to a local GGUF model.
MODEL_PATH=/absolute/path/to/models/gemma-3-1b-it.gguf

# Keep this port aligned with LLAMA_COMPLETION_URL in windsurf-config/mcp.json.
HOST=127.0.0.1
PORT=8090

# Low-VRAM defaults. Increase these on stronger GPUs.
CTX_SIZE=2048
BATCH_SIZE=64
GPU_LAYERS=10
